SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# Claude Code Routines — get routine ID from the routine's URL,
# token from the routine's API trigger config (shown once on creation).

# Generator routine. Vercel Cron fires it daily at 04:00 UTC.
GENERATOR_ROUTINE_ID=
GENERATOR_TRIGGER_TOKEN=sk-ant-oat01-...

# Deep-research routine. Fired on demand when you click "Pursue" on a new idea.
DEEP_RESEARCH_ROUTINE_ID=
DEEP_RESEARCH_TRIGGER_TOKEN=sk-ant-oat01-...

# Validator routine. Fired on demand when you click "Send to validation"
# on a researched idea. Builds landing copy, interview script, $50 ad plan.
VALIDATE_ROUTINE_ID=
VALIDATE_TRIGGER_TOKEN=sk-ant-oat01-...

# Plan-builder routine. Fired on demand when you click "Approve plan"
# on a validated idea. Aborts if the idea isn't validated yet.
PLAN_ROUTINE_ID=
PLAN_TRIGGER_TOKEN=sk-ant-oat01-...

# Post-mortem routine. Vercel Cron fires it weekly (Monday 05:00 UTC) to
# cluster killed-idea reasons into feedback_patterns dislikes.
POSTMORTEM_ROUTINE_ID=
POSTMORTEM_TRIGGER_TOKEN=sk-ant-oat01-...

DASHBOARD_PASSWORD=changeme

# Shared secret Vercel Cron sends as `Authorization: Bearer ${CRON_SECRET}`.
# Required in prod; leave blank locally.
CRON_SECRET=
