SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

DASHBOARD_PASSWORD=changeme

# Shared secret Vercel Cron sends as `Authorization: Bearer ${CRON_SECRET}`.
# Only the sweep-runs cron uses it now (no LLM-triggering crons remain).
CRON_SECRET=

# === Worker-only ===
# Do NOT set ANTHROPIC_API_KEY. The local worker (worker/index.ts) uses the
# user's Claude Code Max OAuth session from macOS Keychain. Setting an API
# key here would silently bill against the API instead of the Max plan, which
# defeats the whole point.

# Optional cap on the worker's daily ROUTINE_RUNS count (3-brake spend guard).
# Default 50. Lower this if you want extra safety while the worker is new.
AI_DAILY_CALL_LIMIT=50
